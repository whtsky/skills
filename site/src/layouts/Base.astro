---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown>;
  bodyLang?: string;
}

const { title, description, canonicalUrl, jsonLd, bodyLang } = Astro.props;
const siteTitle = "Agent Skills by whtsky";
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const canonical = canonicalUrl ?? Astro.url.href;
const ogUrl = canonical;
---

<!doctype html>
<html lang="en" style="color-scheme: light dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:site_name" content={siteTitle} />

    <!-- JSON-LD -->
    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }

    <!-- Umami Analytics -->
    <script
      defer
      src="https://u.whtsky.me/script.js"
      data-website-id="2d105b6e-592b-4025-adc5-ababe34e24db"></script>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="site-title text-link">{siteTitle}</a>
        <a
          href="https://github.com/whtsky/skills"
          target="_blank"
          class="nav-link"
          data-umami-event="click-github-nav">GitHub</a
        >
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        <a
          href="https://github.com/whtsky/skills"
          target="_blank"
          data-umami-event="click-github-footer">whtsky/skills</a
        > &mdash; a collection of <a
          href="https://agentskills.io/"
          target="_blank"
          data-umami-event="click-agentskills">agent skills</a
        > for AI assistants.
      </p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #fafafa;
    --color-text: #2d2d2d;
    --color-muted: #777;
    --color-border: #e8e8e8;
    --color-link: #2563eb;
    --color-link-hover: #1d4ed8;
    --color-badge-bg: #f0f0f0;
    --color-badge-text: #555;
    --color-code-bg: #f0f0f0;
    --color-card-hover-border: #ccc;
    --color-badge-hover-bg: #e4e4e4;
    --max-width: 52rem;
    --font-sans:
      system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --font-mono:
      ui-monospace, "SF Mono", SFMono-Regular, Menlo, Consolas, monospace;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --color-bg: #1c1c1e;
      --color-text: #d4d4d8;
      --color-muted: #8b8b8f;
      --color-border: #2c2c2e;
      --color-link: #60a5fa;
      --color-link-hover: #93c5fd;
      --color-badge-bg: #27272a;
      --color-badge-text: #a1a1aa;
      --color-code-bg: #222224;
      --color-card-hover-border: #3f3f46;
      --color-badge-hover-bg: #303033;
    }
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: var(--font-sans);
    color: var(--color-text);
    background: var(--color-bg);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
    max-width: var(--max-width);
    width: 100%;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  a {
    color: var(--color-link);
    text-decoration: none;
  }
  a:hover {
    color: var(--color-link-hover);
    text-decoration: underline;
  }

  .text-link {
    color: var(--color-text);
  }
  .text-link:hover {
    color: var(--color-link);
    text-decoration: underline;
  }

  h1 {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
  }
  h2 {
    font-size: 1.35rem;
    margin: 2rem 0 0.75rem;
  }
  h3 {
    font-size: 1.1rem;
    margin: 1.5rem 0 0.5rem;
  }

  p {
    margin-bottom: 0.75rem;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-code-bg);
    padding: 0.15em 0.35em;
    border-radius: 3px;
  }

  pre {
    background: var(--color-code-bg);
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    overflow-x: auto;
    margin: 0.5rem 0;
  }

  pre code {
    background: none;
    padding: 0;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin: 0.75rem 0;
    font-size: 0.9rem;
  }

  th,
  td {
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  th {
    font-weight: 600;
  }

  ul,
  ol {
    padding-left: 1.5rem;
    margin-bottom: 0.75rem;
  }
  li {
    margin-bottom: 0.25rem;
  }

  blockquote {
    border-left: 3px solid var(--color-border);
    padding-left: 1rem;
    color: var(--color-muted);
    margin: 0.75rem 0;
  }

  header nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-title {
    font-weight: 600;
    font-size: 1.05rem;
  }

  .nav-link {
    font-size: 0.9rem;
  }

  footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .badge {
    display: inline-block;
    padding: 0.15em 0.5em;
    background: var(--color-badge-bg);
    color: var(--color-badge-text);
    border-radius: 4px;
    font-size: 0.8rem;
    text-decoration: none;
  }
  a.badge:hover {
    background: var(--color-badge-hover-bg);
    color: var(--color-badge-text);
    text-decoration: none;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .page-description {
    color: var(--color-muted);
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
  }

  .skill-grid {
    display: grid;
    gap: 1rem;
  }
</style>
