---
import { CATEGORY_LABELS, REGION_LABELS } from "../lib/catalog";
import type { NormalizedSkill } from "../lib/catalog";

interface Props {
  skill: NormalizedSkill;
}

const { skill } = Astro.props;
---

<article class="skill-card">
  <h3><a href={`/skills/${skill.slug}/`}>{skill.name}</a></h3>
  <p class="skill-description">{skill.description}</p>
  <div class="badges">
    <a class="badge" href={`/categories/${skill.category}/`}>
      {CATEGORY_LABELS[skill.category] ?? skill.category}
    </a>
    {
      skill.regions.map((r) => (
        <a class="badge" href={`/regions/${r}/`}>
          {REGION_LABELS[r] ?? r}
        </a>
      ))
    }
  </div>
</article>

<style>
  .skill-card {
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }
  .skill-card:hover {
    border-color: #ccc;
  }
  .skill-card h3 {
    margin: 0 0 0.35rem;
    font-size: 1rem;
  }
  .skill-description {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
