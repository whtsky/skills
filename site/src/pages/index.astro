---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import SkillCard from "../components/SkillCard.astro";
import CopyCommand from "../components/CopyCommand.astro";
import {
  normalizeAll,
  groupBy,
  orderedCategories,
  CATEGORY_LABELS,
} from "../lib/catalog";

const entries = await getCollection("skills");
const skills = normalizeAll(entries);
const byCategory = groupBy(skills, (s) => s.category);
const categories = orderedCategories(byCategory);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Agent Skills",
  description: `${skills.length}+ ready-to-use agent skills for weather, travel, restaurants, gaming & more — works with OpenClaw, Claude Code, Cursor, and more.`,
  url: Astro.site?.href,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: skills.length,
    itemListElement: skills.map((s, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: s.name,
      url: new URL(`/skills/${s.slug}/`, Astro.site).href,
    })),
  },
};
---

<Base
  title="Agent Skills by whtsky"
  description={`${skills.length}+ ready-to-use agent skills for weather, travel, restaurants, gaming & more — works with OpenClaw, Claude Code, Cursor, and more.`}
  jsonLd={jsonLd}
>
  <p class="page-description">
    A collection of {skills.length} agent skills for weather, travel, restaurants,
    media, and more by <a
      href="https://blog.whtsky.me?utm_source=skills.whtsky.me&utm_medium=web&utm_campaign=agent-skills"
      target="_blank"
      data-umami-event="click-author">whtsky</a
    >. Works with <a
      href="https://openclaw.ai"
      target="_blank"
      data-umami-event="click-openclaw">OpenClaw</a
    >, <a href="https://claude.ai/code" target="_blank" data-umami-event="click-claude-code">Claude Code</a
    >, <a href="https://cursor.sh" target="_blank" data-umami-event="click-cursor">Cursor</a>,
    and more.
  </p>

  <CopyCommand command="npx skills add whtsky/skills" />

  {
    categories.map((cat) => {
      const catSkills = byCategory.get(cat);
      if (!catSkills?.length) return null;
      return (
        <section>
          <h2>
            <a class="text-link" href={`/categories/${cat}/`}>
              {CATEGORY_LABELS[cat] ?? cat}
            </a>
          </h2>
          <div class="skill-grid">
            {catSkills.map((s) => (
              <SkillCard skill={s} />
            ))}
          </div>
        </section>
      );
    })
  }
</Base>
