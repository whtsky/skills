---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import SkillCard from "../components/SkillCard.astro";
import {
  normalizeAll,
  groupBy,
  CATEGORY_ORDER,
  CATEGORY_LABELS,
  REGION_LABELS,
} from "../lib/catalog";

const entries = await getCollection("skills");
const skills = normalizeAll(entries);
const byCategory = groupBy(skills, (s) => s.category);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Agent Skills",
  description: `A collection of ${skills.length} agent skills for AI assistants — weather, travel, food, and more.`,
  url: Astro.site?.href,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: skills.length,
    itemListElement: skills.map((s, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: s.name,
      url: new URL(`/skills/${s.slug}/`, Astro.site).href,
    })),
  },
};

const regionCounts = new Map<string, number>();
for (const s of skills) {
  for (const r of s.regions) {
    regionCounts.set(r, (regionCounts.get(r) ?? 0) + 1);
  }
}
---

<Base
  title="Agent Skills"
  description={`A collection of ${skills.length} agent skills for AI assistants — weather, travel, food, and more.`}
  jsonLd={jsonLd}
>
  <h1>Agent Skills</h1>
  <p class="page-description">
    A collection of {skills.length} agent skills for AI assistants. Weather, travel,
    restaurants, media, and more.
  </p>

  <section class="install-section">
    <h2>Installation</h2>
    <p>Install all skills:</p>
    <pre><code>npx skills add whtsky/skills</code></pre>
    <p>Install a specific skill:</p>
    <pre><code>npx skills add whtsky/skills -s &lt;skill-name&gt;</code></pre>
  </section>

  <section class="browse-section">
    <h2>Browse</h2>
    <div class="browse-links">
      <div>
        <h3>By Category</h3>
        <div class="badges">
          {
            CATEGORY_ORDER.map((cat) => {
              const count = byCategory.get(cat)?.length ?? 0;
              return count > 0 ? (
                <a class="badge" href={`/categories/${cat}/`}>
                  {CATEGORY_LABELS[cat]} ({count})
                </a>
              ) : null;
            })
          }
        </div>
      </div>
      <div>
        <h3>By Region</h3>
        <div class="badges">
          {
            [...regionCounts.entries()]
              .sort((a, b) => b[1] - a[1])
              .map(([region, count]) => (
                <a class="badge" href={`/regions/${region}/`}>
                  {REGION_LABELS[region] ?? region} ({count})
                </a>
              ))
          }
        </div>
      </div>
    </div>
  </section>

  {
    CATEGORY_ORDER.map((cat) => {
      const catSkills = byCategory.get(cat);
      if (!catSkills?.length) return null;
      return (
        <section>
          <h2>
            <a href={`/categories/${cat}/`}>{CATEGORY_LABELS[cat]}</a>
          </h2>
          <div class="skill-grid">
            {catSkills.map((s) => (
              <SkillCard skill={s} />
            ))}
          </div>
        </section>
      );
    })
  }
</Base>

<style>
  .install-section pre {
    display: inline-block;
  }
  .browse-section {
    margin-bottom: 1rem;
  }
  .browse-links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .browse-links h3 {
    margin: 0 0 0.4rem;
    font-size: 0.95rem;
  }
</style>
