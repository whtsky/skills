---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import CopyCommand from "../../components/CopyCommand.astro";
import {
  normalizeSkill,
  CATEGORY_LABELS,
  REGION_LABELS,
} from "../../lib/catalog";
import type { NormalizedSkill } from "../../lib/catalog";

export async function getStaticPaths() {
  const entries = await getCollection("skills");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const skill: NormalizedSkill = normalizeSkill(entry);
const { Content } = await render(entry);

const skillTitle = `${skill.name} — ${skill.description.length > 60 ? skill.description.slice(0, 57) + "..." : skill.description}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: skill.name,
  description: skill.description,
  applicationCategory: "AI Agent Skill",
  codeRepository: skill.sourceUrl,
  keywords: skill.tags.join(", "),
};
---

<Base title={skillTitle} description={skill.description} jsonLd={jsonLd}>
  <div class="skill-header">
    <h1>{skill.name}</h1>
    <p class="skill-description">{skill.description}</p>
    <div class="badges">
      <a class="badge" href={`/categories/${skill.category}/`}>
        {CATEGORY_LABELS[skill.category] ?? skill.category}
      </a>
      {
        skill.regions.map((r) => (
          <a class="badge" href={`/regions/${r}/`}>
            {REGION_LABELS[r] ?? r}
          </a>
        ))
      }
      {
        skill.tags.map((t) => (
          <a class="badge" href={`/tags/${t}/`}>
            {t}
          </a>
        ))
      }
    </div>

    <div class="skill-meta">
      <CopyCommand command={`npx skills add whtsky/skills -s ${skill.slug}`} />
      {
        skill.compatibility && (
          <p class="meta-requirements">{skill.compatibility}</p>
        )
      }
    </div>
  </div>

  <section
    class="skill-body"
    lang={skill.bodyLang !== "en" ? skill.bodyLang : undefined}
  >
    <h2 class="body-heading">Documentation</h2>
    <Content />
  </section>

  <section class="source">
    <p>
      <a
        href={skill.sourceUrl}
        target="_blank"
        data-umami-event="click-source"
        data-umami-event-skill={skill.slug}>View source on GitHub &rarr;</a
      >
    </p>
  </section>
</Base>

<style>
  .skill-header {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2rem;
  }
  .skill-header h1 {
    margin-bottom: 0.35rem;
  }
  .skill-description {
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }
  .skill-meta {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }
  .meta-requirements {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 0;
  }
  .skill-body {
    padding-top: 0;
    margin-top: 0;
  }
  .body-heading {
    font-size: 1.1rem;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
  }
  .source {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
</style>
